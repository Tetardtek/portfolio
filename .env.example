# Portfolio v2 — Environment Variables

# ─── MySQL ────────────────────────────────────────────────
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=portfolio
DB_PASSWORD=
DB_NAME=portfolio_v2

# ─── SuperOAuth (PKCE) ───────────────────────────────────
SUPEROAUTH_URL=https://superoauth.tetardtek.com
SUPEROAUTH_CLIENT_ID=
SUPEROAUTH_REDIRECT_URI=https://portfolio.tetardtek.com/api/auth/pkce/callback

# ─── Public URL (for redirects behind Docker/proxy) ──────
PUBLIC_URL=https://portfolio.tetardtek.com

# ─── Owner check (admin access) ──────────────────────────
# SuperOAuth user ID of the portfolio owner — only this user can access /admin
OWNER_USER_ID=

# ─── Contact form ────────────────────────────────────────
NODEMAILER_HOST=
NODEMAILER_PORT=587
NODEMAILER_USER=
NODEMAILER_PASS=
CONTACT_TO=
